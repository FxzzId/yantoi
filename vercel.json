{
  "version": 2,
  "public": true,
  "rewrites": [
    { "source": "/admin/nisa/imut", "destination": "/admin/nisa/imut/index.html" },
    { "source": "/admin/nisa/imut/", "destination": "/admin/nisa/imut/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
