{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/admin",
      "dest": "/public/admin.html"
    },
    {
      "src": "/admin/(.*)",
      "dest": "/public/admin.html"
    },
    {
      "src": "/profile",
      "dest": "/public/profile.html"
    },
    {
      "src": "/profile/(.*)",
      "dest": "/public/profile.html"
    },
    {
      "src": "/order/(.*)",
      "dest": "/public/order.html"
    },
    {
      "src": "/deposit",
      "dest": "/public/deposit.html"
    },
    {
      "src": "/deposit/(.*)",
      "dest": "/public/deposit.html"
    },
    {
      "src": "/unauthorized",
      "dest": "/public/unauthorized.html"
    },
    {
      "src": "/ketentuan",
      "dest": "/public/ketentuan.html"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}
