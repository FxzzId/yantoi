{
  "version": 2,
  "public": true,
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/admin/(.*)", "destination": "/admin.html" },
    { "source": "/profile", "destination": "/profile.html" },
    { "source": "/profile/(.*)", "destination": "/profile.html" },
    { "source": "/order/(.*)", "destination": "/order.html" },
    { "source": "/deposit", "destination": "/deposit.html" },
    { "source": "/deposit/(.*)", "destination": "/deposit.html" },
    { "source": "/unauthorized", "destination": "/unauthorized.html" },
    { "source": "/ketentuan", "destination": "/ketentuan.html" },
    { "source": "/api/webhook", "destination": "/api/webhook.js" },
    { "source": "/api/(.*)", "destination": "/api/webhook.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
